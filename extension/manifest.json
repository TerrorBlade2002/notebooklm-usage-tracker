{
    "manifest_version": 3,
    "name": "NotebookLM Usage Tracker",
    "version": "1.0.0",
    "key": "",
    "description": "Tracks NotebookLM notebook usage across agents for analytics and reporting",
    "permissions": [
          "storage",
          "nativeMessaging",
          "tabs",
          "scripting"
    ],
    "host_permissions": [
          "https://notebooklm.google.com/*"
    ],
    "background": {
          "service_worker": "background.js"
    },
    "content_scripts": [
          {
                  "matches": ["https://notebooklm.google.com/*"],
                  "js": ["content_script.js"],
                  "run_at": "document_idle"
          }
    ],
    "options_page": "options.html",
    "icons": {
          "16": "icons/icon16.png",
          "48": "icons/icon48.png",
          "128": "icons/icon128.png"
    }
}
